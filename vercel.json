{
  "rewrites": [
    {
      "source": "/admin/(.*)",
      "destination": "/admin/index.html"
    }
  ],
  "headers": [
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ],
  "routes": [
    {
      "src": "/admin/(?!index\\.html$)(.+\\.(js|json|md|txt|html)$)",
      "status": 403,
      "headers": { "Content-Type": "text/plain" },
      "dest": "/404.html"
    }
  ]
}
