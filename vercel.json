{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "sobre.html",
          "politica-privacidade.html",
          "termos-de-uso.html",
          "404.html",
          "ads.txt",
          "robots.txt",
          "sitemap.xml",
          "sitemap-index.xml",
          "assets/**",
          "pages/**",
          "admin/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
